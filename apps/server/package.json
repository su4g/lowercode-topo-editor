{
  "name": "@topo-editor/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "seed": "node --import tsx src/seed.ts",
    "ports:default": "tsx src/scripts/update-default-ports.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@prisma/client": "^5.22.0",
    "@topo-editor/topology-shared": "workspace:*",
    "dotenv": "^16.4.7",
    "fastify": "^4.29.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
