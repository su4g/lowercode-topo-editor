{
  "name": "topo-editor",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @topo-editor/web dev",
    "dev:server": "pnpm --filter @topo-editor/server dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "db:create": "createdb topo_editor || true",
    "db:push": "pnpm --filter @topo-editor/server prisma:push",
    "db:seed": "pnpm --filter @topo-editor/server seed"
  },
  "devDependencies": {
    "@types/node": "^20.19.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@11.7.0"
}
